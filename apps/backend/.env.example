PORT=5000
# On Render, PORT is set automatically; use NODE_ENV=production for logging and security defaults.
NODE_ENV=development
MONGODB_URI=mongodb://localhost:27017/lumora
# Production: exact frontend origin (scheme + host), e.g. https://your-app.onrender.com — required for CORS.
CLIENT_URL=http://localhost:3000
JWT_SECRET=change_me
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh
JWT_REFRESH_EXPIRES_IN=7d
TMDB_API_KEY=your_tmdb_api_key
TMDB_BASE_URL=https://api.themoviedb.org/3
